@implements IAsyncDisposable
@inject IJSRuntime JS

@if (string.IsNullOrEmpty(SequenceA) || string.IsNullOrEmpty(SequenceB)) return;

<div style="background: white; padding: 20px; border-radius: 8px; border: 1px solid #ddd; margin-bottom: 30px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
        <h3 style="font-size: 1.2rem; color: #333; font-weight: bold; margin: 0;">Genomic Dot-Plot</h3>
        
        <div style="display: flex; align-items: center; gap: 15px; background: #eee; padding: 8px 15px; border-radius: 6px;">
            <label for="kmerSlider" style="font-size: 0.9em; color: #444; margin: 0; font-weight: bold;">
                K-mer Size: <span style="color: #007bff;">@_kmerSize bp</span>
            </label>
            <input id="kmerSlider" type="range" min="5" max="50" step="1" 
                   value="@_kmerSize"
                   @oninput="HandleSliderDrag"
                   @onchange="HandleSliderRelease"
                   style="cursor: pointer; width: 150px;" />
        </div>
    </div>
    
    <div style="text-align: center;">
        <canvas id="dotPlotCanvas" width="600" height="600" style="background: #fafafa; border: 1px solid #ccc; max-width: 100%; box-shadow: inset 0 0 10px rgba(0,0,0,0.05);"></canvas>
    </div>
</div>

@code {
    [Parameter] public string SequenceA { get; set; } = string.Empty;
    [Parameter] public string SequenceB { get; set; } = string.Empty;

    private int _kmerSize = 20;

    private IJSObjectReference? _jsModule;
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _jsModule = await JS.InvokeAsync<IJSObjectReference>("import", "./Components/GenomicDotPlot.razor.js");
            
            await GenerateDotPlotAsync();
        }
    }

    private async Task GenerateDotPlotAsync()
    {
        string rawA = SequenceA.Replace("-", "");
        string rawB = SequenceB.Replace("-", "");
        int windowSize = _kmerSize;
        
        var lineSegments = new List<double>();

        await Task.Run(() =>
        {
            var kmerIndex = new Dictionary<string, List<int>>();

            for (int i = 0; i <= rawA.Length - windowSize; i++)
            {
                string kmer = rawA.Substring(i, windowSize);
                if (!kmerIndex.ContainsKey(kmer)) kmerIndex[kmer] = new List<int>();
                kmerIndex[kmer].Add(i);
            }

            var coveredDiagonals = new Dictionary<int, int>();

            for (int j = 0; j <= rawB.Length - windowSize; j++)
            {
                string kmer = rawB.Substring(j, windowSize);
                
                if (kmerIndex.TryGetValue(kmer, out var xPositions))
                {
                    foreach (int x in xPositions)
                    {
                        int diagonalId = x - j;

                        if (coveredDiagonals.TryGetValue(diagonalId, out int maxJ) && j <= maxJ) continue;

                        int len = windowSize;
                        while (x + len < rawA.Length && j + len < rawB.Length && rawA[x + len] == rawB[j + len]) len++;

                        lineSegments.Add(x);
                        lineSegments.Add(j);
                        lineSegments.Add(x + len);
                        lineSegments.Add(j + len);

                        coveredDiagonals[diagonalId] = j + len - 1;
                    }
                }
            }
        });

        if (lineSegments.Any())
        {
            await JS.InvokeVoidAsync("drawDotPlot", "dotPlotCanvas", lineSegments.ToArray(), rawA.Length, rawB.Length);
        }
    }
    
    private void HandleSliderDrag(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int val)) _kmerSize = val;
    }

    private async Task HandleSliderRelease(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int val))
        {
            _kmerSize = val;
            await GenerateDotPlotAsync();
        }
    }

    public async ValueTask DisposeAsync()
    {

        if (_jsModule != null)
        {
            await _jsModule.DisposeAsync();
        }
    }

}