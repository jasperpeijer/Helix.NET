@page "/jobs/{Id:guid}"
@using System.Net.Http.Json
@using System.Text
@inject HttpClient Http

<PageTitle>Job Details - Helix.NET</PageTitle>

<div style="margin-bottom: 20px;">
    <h1>Alignment Job Details</h1>
    <p style="font-family: monospace; color: #666;">Tracking ID: @Id</p>
</div>

@if (_job == null || _job.Status == "Pending" || _job.Status == "Processing")
{
    <div style="padding: 20px; background-color: #f8f9fa; border-left: 4px solid #007bff;">
        <strong>System Status:</strong> @_statusMessage
    </div>
}
else if (_job.Status == "Completed")
{
    <div style="margin-bottom: 10px;">
        <a href="@GetFastaExportLink()"
           download="@($"Helix_Alignment_{@Id.ToString().Substring(0, 8)}.fasta")"
           class="btn btn-primary">
            💾 Save Result (.fasta)
        </a>
    </div>
    
    <div style="font-family: 'Courier New', monospace; background: #f4f4f4; color: #d4d4d4; padding: 20px; border-radius: 4px; overflow-x: auto;">
        @for (int i = 0; i < _job.AlignedSequenceA.Length; i += 60)
        {
            int length = Math.Min(60, _job.AlignedSequenceA.Length - i);

            string chunkA = _job.AlignedSequenceA.Substring(i, length);
            string chunkB = _job.AlignedSequenceB.Substring(i, length);
            
            <div style="margin-bottom: 20px;">
                <div style="color: #999; font-size: 0.75em; margin-bottom: 4px; font-weight: bold;">POS: @(i + 1)</div>
                
                <div style="white-space: pre; letter-spacing: 2px;">
                    @for (int c = 0; c < length; c++)
                    {
                        bool match = chunkA[c] == chunkB[c];
                        <span style="color: @GetColor(chunkA[c], chunkB[c]); font-weight: @(match ? "normal" : "bold");">@chunkA[c]</span>
                    }
                </div>
                
                <div style="white-space: pre; letter-spacing: 2px;">
                    @for (int c = 0; c < length; c++)
                    {
                        bool match = chunkA[c] == chunkB[c];
                        <span style="color: @GetColor(chunkA[c], chunkB[c]); font-weight: @(match ? "normal" : "bold");">@chunkB[c]</span>
                    }
                </div>
            </div>
        }
    </div>
}
else if (_job.Status == "Failed")
{
    <div style="padding: 20px; background-color: #f8d7da; border-left: 4px solid #dc3545;">
        <strong>System Error:</strong> The alignment engine failed to process this sequence.
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private JobResponse? _job;
    private string _statusMessage = "Connecting to compute cluster...";
    
    public class JobResponse
    {
        public Guid Id { get; set; }
        public string Status { get; set; } = string.Empty;
        public int? FinalScore { get; set; }
        public string? AlignedSequenceA { get; set; }
        public string? AlignedSequenceB { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        string apiUrl = "https://localhost:7096/api/v1/align/jobs";
        
        while (true)
        {
            try
            {
                _job = await Http.GetFromJsonAsync<JobResponse>($"{apiUrl}/{Id}");

                if (_job == null)
                {
                    _statusMessage = "Error: Job not found in the database.";
                    break;
                }

                if (_job.Status == "Completed")
                {
                    break;
                }
                
                if (_job.Status == "Failed")
                {
                    _statusMessage = "Error: Job failed to process this sequence.";
                    break;
                }
                
                if (_job.Status == "Pending" || _job.Status == "Processing")
                {
                    _statusMessage = $"Job is {_job.Status.ToLower()}. Refreshing every 5 seconds...";
                    StateHasChanged();
                }
            }
            catch (HttpRequestException)
            {
                _statusMessage = "Error: Job not found in the database.";
                break;
            }

            await Task.Delay(5000);
        }

    }

    private String GetFastaExportLink()
    {
        if (_job == null || string.IsNullOrEmpty(_job.AlignedSequenceA)) return "#";

        string WrapSequence(string sequence)
        {
            var sb = new StringBuilder();

            for (int i = 0; i < sequence.Length; i += 60)
            {
                int remaining = sequence.Length - i;
                sb.AppendLine(sequence.Substring(i, Math.Min(remaining, 60)));
            }

            return sb.ToString().TrimEnd();
        }
        
        string fastaContent = $">Sequence_A_Job_{Id}\n{WrapSequence(_job.AlignedSequenceA)}\n" +
                              $">Sequence_B_Job_{Id}\n{WrapSequence(_job.AlignedSequenceB!)}";

        return $"data:text/plain;charset=utf-8,{Uri.EscapeDataString(fastaContent)}";
    }

    private string GetColor(char current, char partner)
    {
        if (current == partner) return "#444";
        
        if (current == '-' || partner == '-') return "#6f42c1";
        
        return "#dc3545";
    }

}